{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 26,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "dev",
      "displayName": "Developer build",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "PATCHY_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "dev-vcpkg",
      "displayName": "Developer build with vcpkg manifest",
      "inherits": "dev",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "VCPKG_FEATURE_FLAGS": "manifests"
      }
    },
    {
      "name": "qt-local",
      "displayName": "Developer build with local Qt install",
      "inherits": "dev",
      "binaryDir": "${sourceDir}/build/app",
      "cacheVariables": {
        "PATCHY_BUILD_APP": "ON",
        "CMAKE_PREFIX_PATH": "${sourceDir}/.deps/Qt/6.8.3/msvc2022_64"
      }
    },
    {
      "name": "release",
      "displayName": "Release build",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "PATCHY_BUILD_TESTS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev",
      "configurePreset": "dev"
    },
    {
      "name": "dev-vcpkg",
      "configurePreset": "dev-vcpkg"
    },
    {
      "name": "qt-local",
      "configurePreset": "qt-local"
    },
    {
      "name": "release",
      "configurePreset": "release"
    }
  ],
  "testPresets": [
    {
      "name": "dev",
      "configurePreset": "dev",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "qt-local",
      "configurePreset": "qt-local",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
