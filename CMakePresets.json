{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 26,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "dev",
      "displayName": "Developer build",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_PREFIX_PATH": "${sourceDir}/.deps/Qt/6.8.3/msvc2022_64",
        "PATCHY_BUILD_APP": "ON",
        "PATCHY_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "dev-vcpkg",
      "displayName": "Developer build with vcpkg manifest",
      "inherits": "dev",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "VCPKG_FEATURE_FLAGS": "manifests"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug build",
      "inherits": "dev"
    },
    {
      "name": "qt-local",
      "displayName": "Developer build with local Qt install",
      "inherits": "dev",
      "binaryDir": "${sourceDir}/build/app",
      "cacheVariables": {
        "PATCHY_BUILD_APP": "ON",
        "CMAKE_PREFIX_PATH": "${sourceDir}/.deps/Qt/6.8.3/msvc2022_64"
      }
    },
    {
      "name": "release",
      "displayName": "Release build",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_PREFIX_PATH": "${sourceDir}/.deps/Qt/6.8.3/msvc2022_64",
        "PATCHY_BUILD_APP": "ON",
        "PATCHY_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "mac-release",
      "displayName": "macOS release build",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/mac-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_PREFIX_PATH": "${sourceDir}/.deps/Qt/6.8.3/macos",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "12.0",
        "PATCHY_BUILD_APP": "ON",
        "PATCHY_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "mac-dev",
      "displayName": "macOS developer build",
      "inherits": "mac-release",
      "binaryDir": "${sourceDir}/build/mac-dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "linux-release",
      "displayName": "Linux release build",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_PREFIX_PATH": "${sourceDir}/.deps/Qt/6.8.3/gcc_64",
        "PATCHY_BUILD_APP": "ON",
        "PATCHY_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "linux-dev",
      "displayName": "Linux developer build",
      "inherits": "linux-release",
      "binaryDir": "${sourceDir}/build/linux-dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev",
      "configurePreset": "dev"
    },
    {
      "name": "dev-vcpkg",
      "configurePreset": "dev-vcpkg"
    },
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "qt-local",
      "configurePreset": "qt-local"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "mac-release",
      "configurePreset": "mac-release"
    },
    {
      "name": "mac-dev",
      "configurePreset": "mac-dev"
    },
    {
      "name": "linux-release",
      "configurePreset": "linux-release"
    },
    {
      "name": "linux-dev",
      "configurePreset": "linux-dev"
    }
  ],
  "testPresets": [
    {
      "name": "dev",
      "configurePreset": "dev",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "qt-local",
      "configurePreset": "qt-local",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
